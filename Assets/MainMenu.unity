  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Siyah Asker**\r\n\r\nVali Odius'un ordusundaki en temel birliklerden
    biri olan Siyah Asker, \xF6zel yeteneklere veya \xFCst\xFCn g\xFCce sahip de\u011Fildir.
    Ortalama dayan\u0131kl\u0131l\u0131\u011F\u0131 ve sald\u0131r\u0131 g\xFCc\xFCyle
    sava\u015F alan\u0131nda g\xF6revini yerine getiren s\u0131radan bir askerdir.\r\n\r\nTek
    ba\u015F\u0131na b\xFCy\xFCk bir tehdit olu\u015Fturmasa da kalabal\u0131k gruplar
    halinde hareket etti\u011Finde rakipleri zor durumda b\u0131rakabilir. Odius'un
    ordusunun say\u0131ca \xFCst\xFCnl\xFC\u011F\xFCn\xFC sa\u011Flayan temel g\xFC\xE7lerden
    biridir.\r\n\r\n**Etkile\u015Fimde Bulundu\u011Fu Kartlar**\r\n\u2022 Yok\r\n\r\n**Kart
    T\xFCr\xFC**\r\n\xD6n ve Arka S\u0131ra Kart\u0131\r\n"
  m_isRightToLeft: 0
