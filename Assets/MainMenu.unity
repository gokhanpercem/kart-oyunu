  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Ninja**\r\n\r\nVali Odius'un gizli birlikleri aras\u0131nda yer alan
    Ninja, dayan\u0131kl\u0131l\u0131ktan \xE7ok h\u0131z ve sald\u0131r\u0131 becerilerine
    g\xFCvenir. D\xFC\u015F\xFCk can de\u011Ferine sahip olmas\u0131na ra\u011Fmen
    ortalaman\u0131n \xFCzerinde sald\u0131r\u0131 g\xFCc\xFCyle rakiplerine h\u0131zl\u0131
    ve beklenmedik darbeler indirebilir.\r\n\r\nG\xF6lgelere kar\u0131\u015Farak
    do\u011Fru an\u0131 bekleyen Ninja, savunmas\u0131z kalan d\xFC\u015Fmanlar\u0131
    hedef al\u0131r ve k\u0131sa s\xFCrede sava\u015F\u0131n dengesini de\u011Fi\u015Ftirebilir.
    Ancak a\xE7\u0131k \xE7at\u0131\u015Fmalarda uzun s\xFCre dayanmas\u0131 zordur.\r\n\r\n**Etkile\u015Fimde
    Bulundu\u011Fu Kartlar**\r\n\u2022 Yok\r\n\r\n**Kart T\xFCr\xFC**\r\nArka S\u0131ra
    Kart\u0131\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
