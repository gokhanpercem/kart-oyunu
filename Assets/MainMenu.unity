  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Hileli Pusula**\r\n\r\nKumandan'\u0131n sava\u015F alan\u0131n\u0131
    manip\xFCle etmek i\xE7in kulland\u0131\u011F\u0131 bu \xF6zel ara\xE7, s\u0131radan
    bir pusula de\u011Fildir. Yanl\u0131\u015F y\xF6nler g\xF6stererek rakip birliklerin
    d\xFCzenini bozar ve d\xFC\u015Fman saflar\u0131nda karma\u015Fa yarat\u0131r.\r\n\r\nRakibin
    planlar\u0131n\u0131 bozmak i\xE7in kullan\u0131lan Hileli Pusula, do\u011Fru
    zamanda uyguland\u0131\u011F\u0131nda sava\u015F d\xFCzenini tamamen de\u011Fi\u015Ftirebilir
    ve avantaj sa\u011Flayabilir.\r\n\r\n**Etkile\u015Fimde Bulundu\u011Fu Kartlar**\r\n\u2022
    Kumandan\r\n\r\n**Kart T\xFCr\xFC**\r\nStratejik Kart\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
