--- !u!114 &422839366
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 422839364}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Wallace**\r\n\r\nCharles Darwin'\u0131n sad\u0131k yol arkada\u015F\u0131
    olan Wallace, k\xFC\xE7\xFCk boyutuna ra\u011Fmen beklenenden \xE7ok daha tehlikeli
    bir maymundur. Savunma konusunda vasat\u0131n alt\u0131nda kalsa da \xE7evikli\u011Fi
    ve sald\u0131rgan yap\u0131s\u0131 sayesinde rakiplerine ciddi hasarlar verebilir.\r\n\r\nSava\u015F
    alan\u0131nda s\xFCrekli hareket halinde olan Wallace, f\u0131rsat buldu\u011Fu
    anda rakiplerinin \xFCzerine at\u0131larak onlar\u0131 haz\u0131rl\u0131ks\u0131z
    yakalar. Dayan\u0131kl\u0131l\u0131\u011F\u0131 s\u0131n\u0131rl\u0131 olsa da
    sald\u0131r\u0131 g\xFCc\xFC, onu hafife alanlar i\xE7in pahal\u0131ya mal olabilir.\r\n\r\n**Etkile\u015Fimde
    Bulundu\u011Fu Kartlar**\r\n\u2022 Yok\r\n\r\n**Kart T\xFCr\xFC**\r\nArka S\u0131ra
    Kart\u0131\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
