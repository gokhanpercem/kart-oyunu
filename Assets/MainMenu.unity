  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Bozuk Pusula**\r\n\r\n\u0130lk bak\u0131\u015Fta i\u015Fe yaramaz gibi
    g\xF6r\xFCnen bu kusurlu pusula, asl\u0131nda Alexandra'n\u0131n en sinsi ara\xE7lar\u0131ndan
    biridir. Kullan\u0131ld\u0131\u011F\u0131nda rakip birliklerin dizili\u015Fini
    bozarak sava\u015F alan\u0131nda kaos yarat\u0131r ve d\xFC\u015Fman\u0131n planlar\u0131n\u0131
    alt\xFCst eder.\r\n\r\nDo\u011Fru zamanda kullan\u0131lan bir Bozuk Pusula, rakibin
    savunmas\u0131n\u0131 zay\u0131flatabilir ve beklenmedik sald\u0131r\u0131lar
    i\xE7in f\u0131rsat olu\u015Fturabilir.\r\n\r\n**Etkile\u015Fimde Bulundu\u011Fu
    Kartlar**\r\n\u2022 Alexandra\r\n\r\n**Kart T\xFCr\xFC**\r\nStratejik Kart\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
