  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Patlay\u0131c\u0131 Uzman\u0131 Luigi**\r\n\r\nBarut, fitil ve patlamalar
    konusunda e\u015Fsiz bir bilgiye sahip olan Luigi, sava\u015F alan\u0131nda kaos
    yaratmay\u0131 seven tehlikeli bir uzmand\u0131r. Orta seviyedeki can\u0131na
    ra\u011Fmen ortalaman\u0131n \xFCzerindeki sald\u0131r\u0131 g\xFCc\xFC sayesinde
    rakiplerine ciddi zarar verebilir.\r\n\r\nHer patlamay\u0131 bir sanat eseri
    olarak g\xF6ren Luigi, d\xFC\u015Fman hatlar\u0131n\u0131 bozmak ve rakiplerine
    zor anlar ya\u015Fatmak i\xE7in her f\u0131rsat\u0131 de\u011Ferlendirir. Nerede
    ortaya \xE7\u0131kaca\u011F\u0131 belli olmayan bu uzman, sava\u015F\u0131n seyrini
    tek bir hamleyle de\u011Fi\u015Ftirebilir.\r\n\r\n**Etkile\u015Fimde Bulundu\u011Fu
    Kartlar**\r\n\u2022 Yok\r\n\r\n**Kart T\xFCr\xFC**\r\n\xD6n ve Arka S\u0131ra
    Kart\u0131\r\n"
  m_isRightToLeft: 0
