  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Ota Benga**\r\n\r\nZorlu tarlalarda ge\xE7en y\u0131llar, Ota Benga'y\u0131
    dayan\u0131kl\u0131 ve kararl\u0131 bir sava\u015F\xE7\u0131ya d\xF6n\xFC\u015Ft\xFCrm\xFC\u015Ft\xFCr.
    Ne en g\xFC\xE7l\xFC ne de en zay\u0131f olan bu kart, dengeli can ve sald\u0131r\u0131
    de\u011Ferleri sayesinde hemen her durumda g\xF6revini yerine getirebilir.\r\n\r\n\xC7etin
    ko\u015Fullar alt\u0131nda hayatta kalmay\u0131 \xF6\u011Frenmi\u015F olan Ota
    Benga, de\u011Fi\u015Fen sava\u015F \u015Fartlar\u0131na kolayca uyum sa\u011Flar
    ve ihtiya\xE7 duyulan her noktada tak\u0131m\u0131na destek olabilir.\r\n\r\n**Etkile\u015Fimde
    Bulundu\u011Fu Kartlar**\r\n\u2022 Yok\r\n\r\n**Kart T\xFCr\xFC**\r\n\xD6n ve
    Arka S\u0131ra Kart\u0131\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
