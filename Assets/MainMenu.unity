  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**DR. Morrow**\r\n\r\nKeskin zek\xE2s\u0131 ve t\u0131bbi bilgisiyle tan\u0131nan
    DR. Morrow, sava\u015F alan\u0131nda kaba kuvvet yerine bilgi ve dayan\u0131kl\u0131l\u0131\u011Fa
    g\xFCvenir. Y\xFCksek can de\u011Ferine sahip olmas\u0131na ra\u011Fmen sald\u0131r\u0131
    g\xFCc\xFC olduk\xE7a d\xFC\u015F\xFCkt\xFCr ve do\u011Frudan \xE7at\u0131\u015Fmalarda
    etkili de\u011Fildir.\r\n\r\nAncak DR. Morrow'un ger\xE7ek g\xFCc\xFC, \xFCzerinde
    \xE7al\u0131\u015Ft\u0131\u011F\u0131 gizemli deneylerde ve ameliyatlar\u0131nda
    sakl\u0131d\u0131r. **Antik Ameliyat Masas\u0131** ile bir araya geldi\u011Finde,
    en b\xFCy\xFCk zay\u0131fl\u0131\u011F\u0131n\u0131 avantaja d\xF6n\xFC\u015Ft\xFCrebilir
    ve sava\u015F\u0131n seyrini beklenmedik \u015Fekillerde de\u011Fi\u015Ftirebilir.\r\n\r\n**Etkile\u015Fimde
    Bulundu\u011Fu Kartlar**\r\n\u2022 Antik Ameliyat Masas\u0131\r\n\r\n**Kart T\xFCr\xFC**\r\n\xD6n
    S\u0131ra Kart\u0131\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
