  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Pusula**\r\n\r\nAlexandra'n\u0131n kulland\u0131\u011F\u0131 \xF6zel
    pusulalardan biri olan bu stratejik ara\xE7, sava\u015F alan\u0131ndaki d\xFCzeni
    yeniden \u015Fekillendirme g\xFCc\xFCne sahiptir. Kullan\u0131ld\u0131\u011F\u0131nda
    Alexandra, stratejik dehas\u0131n\u0131 kullanarak tak\u0131m\u0131n\u0131n dizili\u015Fini
    yeniden d\xFCzenler ve sava\u015F\u0131n ak\u0131\u015F\u0131na uygun yeni bir
    formasyon olu\u015Fturur.\r\n\r\nDo\u011Fru zamanda kullan\u0131lan bir Pusula,
    kaybedilmek \xFCzere olan bir \xE7at\u0131\u015Fmay\u0131 bile zafere d\xF6n\xFC\u015Ft\xFCrebilir.\r\n\r\n**Etkile\u015Fimde
    Bulundu\u011Fu Kartlar**\r\n\u2022 Alexandra\r\n\r\n**Kart T\xFCr\xFC**\r\nStratejik
    Kart\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
