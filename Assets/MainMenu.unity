  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Mistik**\r\n\r\nDo\u011Fan\u0131n kadim g\xFCc\xFCn\xFC bedeninde ta\u015F\u0131yan
    Mistik, yer alt\u0131ndan, topraktan ve vah\u015Fi do\u011Fadan ald\u0131\u011F\u0131
    enerjiyle sava\u015F alan\u0131na h\xFCkmeder. Ortalama \xFCzerindeki can ve
    sald\u0131r\u0131 de\u011Ferleri sayesinde hem dayan\u0131kl\u0131 hem de tehlikeli
    bir d\xF6v\xFC\u015F\xE7\xFCd\xFCr.\r\n\r\nTopra\u011F\u0131n \xF6fkesi ve do\u011Fan\u0131n
    g\xFCc\xFC onun silahlar\u0131d\u0131r. Sava\u015F ba\u015Flad\u0131\u011F\u0131nda
    rakiplerine ac\u0131mas\u0131zca sald\u0131r\u0131r ve kar\u015F\u0131s\u0131na
    \xE7\u0131kan her engeli y\u0131kmaya \xE7al\u0131\u015F\u0131r. G\xFC\xE7 ile
    dayan\u0131kl\u0131l\u0131\u011F\u0131 bir araya getiren Mistik, sava\u015F alan\u0131nda
    her zaman ciddiye al\u0131nmas\u0131 gereken bir tehdittir.\r\n\r\n**Etkile\u015Fimde
    Bulundu\u011Fu Kartlar**\r\n\u2022 Yok\r\n\r\n**Kart T\xFCr\xFC**\r\n\xD6n ve
    Arka S\u0131ra Kart\u0131\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
