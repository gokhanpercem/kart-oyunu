  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Ok\xE7u**\r\n\r\nVali Odius'un ordusundaki uzak menzilli birliklerden
    biri olan Ok\xE7u, d\xFC\u015F\xFCk dayan\u0131kl\u0131l\u0131\u011F\u0131na
    ra\u011Fmen y\xFCksek sald\u0131r\u0131 g\xFCc\xFCyle rakipleri i\xE7in b\xFCy\xFCk
    bir tehdit olu\u015Fturur.\r\n\r\nG\xFCvenli mesafeden sald\u0131rmay\u0131 tercih
    eden Ok\xE7u, korunabildi\u011Fi s\xFCrece sava\u015F alan\u0131nda s\xFCrekli
    bask\u0131 kurabilir. Ancak savunmas\u0131 zay\u0131f oldu\u011Fu i\xE7in yak\u0131n
    \xE7at\u0131\u015Fmalarda kolayca etkisiz hale getirilebilir.\r\n\r\n**Etkile\u015Fimde
    Bulundu\u011Fu Kartlar**\r\n\u2022 Yok\r\n\r\n**Kart T\xFCr\xFC**\r\nArka S\u0131ra
    Kart\u0131\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
