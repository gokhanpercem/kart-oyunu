  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Kay\u0131p Amiral**\r\n\r\nY\u0131llar boyunca denizlerde bir efsane
    olarak anlat\u0131lan Kay\u0131p Amiral, Alexandra'n\u0131n bitmek bilmeyen aray\u0131\u015Flar\u0131
    sonucunda yeniden sava\u015F alan\u0131na d\xF6ner. Y\xFCksek can ve sald\u0131r\u0131
    g\xFCc\xFCyle ordunun \xF6n saf\u0131nda yer al\u0131r, kar\u015F\u0131s\u0131na
    \xE7\u0131kan her tehdidi ezip ge\xE7ebilecek kudrete sahiptir.\r\n\r\nOyunun
    en g\xFC\xE7l\xFC kartlar\u0131ndan biri olan Kay\u0131p Amiral, sahaya indi\u011Fi
    andan itibaren sava\u015F\u0131n dengesini de\u011Fi\u015Ftirebilir ve rakip
    \xFCzerinde b\xFCy\xFCk bir bask\u0131 kurar.\r\n\r\n**Etkile\u015Fimde Bulundu\u011Fu
    Kartlar**\r\n\u2022 Alexandra\r\n\u2022 Amiralin Pusulas\u0131\r\n\r\n**Kart
    T\xFCr\xFC**\r\n\xD6n S\u0131ra Kart\u0131\r\n"
  m_isRightToLeft: 0
