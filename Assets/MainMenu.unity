  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Serum Ask\u0131s\u0131**\r\n\r\nEvelyn'in haz\u0131rlad\u0131\u011F\u0131
    g\xFC\xE7lendirici serumlar\u0131 ta\u015F\u0131yan bu \xF6zel d\xFCzenek, sava\u015F
    alan\u0131nda m\xFCttefiklerin performans\u0131n\u0131 art\u0131rmak i\xE7in
    kullan\u0131l\u0131r. Serum Ask\u0131s\u0131'n\u0131n etkisi alt\u0131ndaki bir
    kart, her tur **+1 Can** ve **+1 Hasar** kazan\u0131r.\r\n\r\n\u0130lk bak\u0131\u015Fta
    m\xFCtevaz\u0131 g\xF6r\xFCnse de, zaman ge\xE7tik\xE7e sa\u011Flad\u0131\u011F\u0131
    g\xFC\xE7 art\u0131\u015F\u0131 rakipler i\xE7in ciddi bir tehdide d\xF6n\xFC\u015Febilir.
    \xD6zellikle uzun s\xFCren m\xFCcadelelerde Serum Ask\u0131s\u0131'n\u0131n etkisi
    sava\u015F\u0131n sonucunu belirleyebilir.\r\n\r\n**Etkile\u015Fimde Bulundu\u011Fu
    Kartlar**\r\n\u2022 Evelyn\r\n\r\n**Kart T\xFCr\xFC**\r\nStratejik Kart\r\n"
