  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**\u015E\xF6valye**\r\n\r\nVali Odius'un ordusundaki a\u011F\u0131r z\u0131rhl\u0131
    birliklerden biri olan \u015E\xF6valye, y\xFCksek dayan\u0131kl\u0131l\u0131\u011F\u0131
    ve sa\u011Flam savunmas\u0131yla \xF6n saflarda sava\u015F\u0131r. Ortalama sald\u0131r\u0131
    g\xFCc\xFCne sahip olsa da kolay kolay y\u0131k\u0131lmayan yap\u0131s\u0131
    sayesinde rakiplerin ilerleyi\u015Fini durdurabilir.\r\n\r\nG\xF6revi b\xFCy\xFCk
    hasarlar vermekten \xE7ok, sava\u015F alan\u0131nda zaman kazanmak ve arkas\u0131ndaki
    birliklere g\xFCvenli bir alan olu\u015Fturmakt\u0131r. Uzun s\xFCren \xE7at\u0131\u015Fmalarda
    dayan\u0131kl\u0131l\u0131\u011F\u0131 sayesinde b\xFCy\xFCk bir tehdit haline
    gelir.\r\n\r\n**Etkile\u015Fimde Bulundu\u011Fu Kartlar**\r\n\u2022 Yok\r\n\r\n**Kart
    T\xFCr\xFC**\r\n\xD6n S\u0131ra Kart\u0131\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
