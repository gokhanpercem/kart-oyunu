  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Evelyn**\r\n\r\nDR. Morrow'un en g\xFCvendi\u011Fi yard\u0131mc\u0131s\u0131
    olan Evelyn, bilgi, beceri ve disiplinin kusursuz bir birle\u015Fimidir. Orta
    seviyedeki can ve sald\u0131r\u0131 de\u011Ferleri sayesinde hem destekleyici
    hem de m\xFCcadeleci bir rol \xFCstlenebilir.\r\n\r\nT\u0131bbi konulardaki uzmanl\u0131\u011F\u0131yla
    tan\u0131nan Evelyn'in en b\xFCy\xFCk yetene\u011Fi ise g\xFC\xE7l\xFC serumlar
    haz\u0131rlamakt\u0131r. Do\u011Fru ekipmanla bir araya geldi\u011Finde, m\xFCttefiklerine
    \xF6nemli avantajlar sa\u011Flayabilir ve sava\u015F\u0131n gidi\u015Fat\u0131n\u0131
    de\u011Fi\u015Ftirebilir.\r\n\r\n**Etkile\u015Fimde Bulundu\u011Fu Kartlar**\r\n\u2022
    Serum Ask\u0131s\u0131\r\n\r\n**Kart T\xFCr\xFC**\r\n\xD6n ve Arka S\u0131ra
    Kart\u0131\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
