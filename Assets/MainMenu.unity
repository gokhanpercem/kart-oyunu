  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Amiralin Pusulas\u0131**\r\n\r\nY\xFCzy\u0131llard\u0131r kay\u0131p
    oldu\u011Fu d\xFC\u015F\xFCn\xFClen bu kadim pusula, denizlerin en b\xFCy\xFCk
    efsanelerinden birine giden yolu g\xF6sterir. Kullan\u0131ld\u0131ktan sonraki
    turda, oyunun en g\xFC\xE7l\xFC kartlar\u0131ndan biri olan **Kay\u0131p Amiral**
    otomatik olarak sava\u015F alan\u0131na gelir.\r\n\r\nSava\u015F\u0131 tek ba\u015F\u0131na
    kazanamayabilir, ancak do\u011Fru zamanda kullan\u0131lan bir Amiralin Pusulas\u0131
    oyunun kaderini de\u011Fi\u015Ftirebilir.\r\n\r\n**Etkile\u015Fimde Bulundu\u011Fu
    Kartlar**\r\n\u2022 Alexandra\r\n\u2022 Kay\u0131p Amiral\r\n\r\n**Kart T\xFCr\xFC**\r\nStratejik
    Kart\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
