--- !u!114 &763460305
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 763460303}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Subay**\r\n\r\nVali Odius'un ordusunda g\xF6rev yapan Subay, sava\u015F
    alan\u0131nda disiplinli hareketleri ve tecr\xFCbesiyle \xF6ne \xE7\u0131kar.
    Ortalama dayan\u0131kl\u0131l\u0131\u011F\u0131na ra\u011Fmen sahip oldu\u011Fu
    g\xFC\xE7l\xFC sald\u0131r\u0131 yetene\u011Fi sayesinde rakiplerine ciddi tehdit
    olu\u015Fturur.\r\n\r\nNe en g\xFC\xE7l\xFC ne de en zay\u0131f birliklerden
    biri olan Subay, do\u011Fru konumland\u0131r\u0131ld\u0131\u011F\u0131nda sava\u015F
    d\xFCzeninin \xF6nemli par\xE7alar\u0131ndan biri haline gelir.\r\n\r\n**Etkile\u015Fimde
    Bulundu\u011Fu Kartlar**\r\n\u2022 Yok\r\n\r\n**Kart T\xFCr\xFC**\r\n\xD6n ve
    Arka S\u0131ra Kart\u0131\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
