  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Kumandan Pusulas\u0131**\r\n\r\nKumandan'\u0131n sava\u015F alan\u0131n\u0131
    kontrol etmek i\xE7in kulland\u0131\u011F\u0131 bu \xF6zel pusula, birliklerin
    konumlar\u0131n\u0131 an\u0131nda de\u011Fi\u015Ftirebilmesini sa\u011Flar. Kullan\u0131ld\u0131\u011F\u0131nda
    Kumandan, kendi ordusunun dizili\u015Fini yeniden d\xFCzenleyerek sava\u015F
    d\xFCzenini rakibin hamlelerine g\xF6re \u015Fekillendirir.\r\n\r\nDo\u011Fru
    zamanda kullan\u0131lan bir Kumandan Pusulas\u0131, savunmay\u0131 g\xFC\xE7lendirebilir
    veya beklenmedik sald\u0131r\u0131lar i\xE7in yeni f\u0131rsatlar olu\u015Fturabilir.\r\n\r\n**Etkile\u015Fimde
    Bulundu\u011Fu Kartlar**\r\n\u2022 Kumandan\r\n\r\n**Kart T\xFCr\xFC**\r\nStratejik
    Kart\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
