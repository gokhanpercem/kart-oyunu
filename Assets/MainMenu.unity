  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "**Vali Odius**\r\n\r\nSava\u015F alan\u0131na ad\u0131m att\u0131\u011F\u0131
    anda dengeleri de\u011Fi\u015Ftiren Vali Odius, s\u0131radan komutanlar\u0131n
    \xE7ok \xF6tesinde bir g\xFCce sahiptir. Zek\xE2s\u0131, otoritesi ve sava\u015F
    yetene\u011Fiyle rakiplerinin t\xFCm planlar\u0131n\u0131 bo\u015Fa \xE7\u0131karabilecek
    seviyede tehlikeli bir varl\u0131kt\u0131r.\r\n\r\nKay\u0131p Amiral gibi efsanevi
    sava\u015F\xE7\u0131lar bile onun kar\u015F\u0131s\u0131nda dikkatli olmak zorundad\u0131r.
    \xD6n veya arka safta fark etmeksizin g\xFCc\xFCn\xFC g\xF6sterebilen Vali Odius,
    sava\u015F\u0131n kaderini tek ba\u015F\u0131na de\u011Fi\u015Ftirebilecek nadir
    karakterlerden biridir.\r\n\r\n**Etkile\u015Fimde Bulundu\u011Fu Kartlar**\r\n\u2022
    Yok\r\n\r\n**Kart T\xFCr\xFC**\r\n\xD6n ve Arka S\u0131ra Kart\u0131\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
